# ──────────────────────────────────────────────────────────────
# Nebula Dominion — Local Development Environment
# Copy to .env and adjust values before running docker compose.
# ──────────────────────────────────────────────────────────────

NODE_ENV=development

# ─── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=nebula
POSTGRES_PASSWORD=nebula_dev_password
POSTGRES_DB=nebula_dominion
POSTGRES_PORT=5432
DATABASE_URL=postgresql://nebula:nebula_dev_password@postgres:5432/nebula_dominion

# ─── Redis ─────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ─── MinIO (S3-compatible object storage) ──────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Service Ports ─────────────────────────────────────────────
WEB_PORT=3000
API_PORT=4000
GAME_SERVER_PORT=4001

# ─── Frontend (Next.js public vars) ────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GAME_SERVER_URL=http://localhost:4001

# ─── Matchmaking tuning ────────────────────────────────────────
MATCHMAKING_INITIAL_ELO_RANGE=100
MATCHMAKING_ELO_EXPANSION_RATE=50
MATCHMAKING_EXPANSION_INTERVAL_MS=10000
MATCHMAKING_MAX_WAIT_MS=120000
MATCHMAKING_TICK_INTERVAL_MS=2000

# ─── Game Server ───────────────────────────────────────────────
GAME_ROOM_TTL_SECONDS=3600
RECONNECT_WINDOW_MS=30000
MAX_ACTIONS_PER_SECOND=10
MAX_ROUND_DURATION_MS=30000

# ─── Telemetry ─────────────────────────────────────────────────
# Set to a strong random string to require X-Telemetry-Key header on /api/v1/events
# Leave empty to disable auth (useful in development)
TELEMETRY_API_KEY=
