.DS_Store

# TypeScript incremental build cache — local artifact, regenerated on
# every `tsc` run; checking it in causes spurious diffs every time
# anyone runs the typechecker.
*.tsbuildinfo

# Claude Code agent worktrees — created by `isolation: "worktree"`
# agents. The runtime locks and cleans them up; nothing inside should
# ever be checked into the main repo history.
.claude/worktrees/
