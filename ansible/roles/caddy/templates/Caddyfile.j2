{
    # Global options
    email admin@{{ domain_name }}
    storage file_system /data/caddy
    log {
        level INFO
        output file /var/log/caddy/access.log {
            roll_size 50mb
            roll_keep 5
        }
    }
}

# Main app proxy (internal to HAProxy)
:8080 {
    encode gzip zstd

    # Health check
    handle /health {
        respond "OK" 200
    }

    # Next.js frontend
    handle {
        reverse_proxy localhost:3000 {
            health_uri /api/health
            health_interval 10s
            lb_policy least_conn
        }
    }
}

# MinIO S3 API
:9000 {
    reverse_proxy localhost:{{ minio_port }} {
        header_up Host {host}
    }
}

# MinIO Console
:9001 {
    reverse_proxy localhost:{{ minio_console_port }} {
        header_up Host {host}
    }
}

# Monitoring (restricted to private network)
:3000 {
    @private_only remote_ip {{ private_network_cidr }}
    handle @private_only {
        reverse_proxy localhost:3000
    }
    handle {
        respond "Forbidden" 403
    }
}
