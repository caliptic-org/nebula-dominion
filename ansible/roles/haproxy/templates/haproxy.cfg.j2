global
    maxconn 50000
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon
    tune.ssl.default-dh-param 2048

defaults
    mode http
    log     global
    option  httplog
    option  dontlognull
    option  forwardfor
    option  http-server-close
    timeout connect 5s
    timeout client  30s
    timeout server  30s
    timeout tunnel  1h
    errorfile 400 /etc/haproxy/errors/400.http
    errorfile 403 /etc/haproxy/errors/403.http
    errorfile 408 /etc/haproxy/errors/408.http
    errorfile 500 /etc/haproxy/errors/500.http
    errorfile 502 /etc/haproxy/errors/502.http
    errorfile 503 /etc/haproxy/errors/503.http
    errorfile 504 /etc/haproxy/errors/504.http

# ── Stats ──────────────────────────────────────────────────────────────────
frontend stats
    bind *:{{ haproxy_stats_port }}
    mode http
    stats enable
    stats uri /stats
    stats realm HAProxy\ Statistics
    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}
    stats refresh 10s
    stats show-node
    stats show-legends

# ── HTTP/HTTPS frontend ────────────────────────────────────────────────────
frontend web_frontend
    bind *:80
    bind *:443 ssl crt /etc/ssl/nebula/nebula.pem alpn h2,http/1.1
    redirect scheme https code 301 if !{ ssl_fc }
    http-request add-header X-Forwarded-Proto https if { ssl_fc }
    http-request set-header X-Real-IP %[src]

    # Cloudflare IP check
    acl from_cloudflare src -f /etc/haproxy/cloudflare_ips.txt
    http-request deny unless from_cloudflare

    # Routing
    acl is_api path_beg /api
    acl is_socket path_beg /socket.io

    use_backend api_servers if is_api
    use_backend game_servers if is_socket
    default_backend web_servers

# ── Web app backend ────────────────────────────────────────────────────────
backend web_servers
    balance leastconn
    option httpchk GET /api/health HTTP/1.1\r\nHost:\ localhost
    http-check expect status 200
    default-server inter 2s fall 3 rise 2
    server srv1-web {{ server1_private_ip }}:3000 check
    server srv2-web {{ server2_private_ip }}:3000 check

# ── API backend ────────────────────────────────────────────────────────────
backend api_servers
    balance leastconn
    option httpchk GET /api/health
    http-check expect status 200
    default-server inter 2s fall 3 rise 2
    server srv1-api {{ server1_private_ip }}:3001 check
    server srv2-api {{ server2_private_ip }}:3001 check

# ── Game / Socket.io backend (sticky sessions) ───────────────────────────
backend game_servers
    balance source
    option http-server-close
    option forwardfor
    default-server inter 2s fall 3 rise 2
    cookie SERVERID insert indirect nocache
    server srv1-game {{ server1_private_ip }}:3002 check cookie srv1
    server srv2-game {{ server2_private_ip }}:3002 check cookie srv2

# ── PostgreSQL primary (read/write) ───────────────────────────────────────
frontend pgsql_primary
    bind *:5000
    mode tcp
    option tcplog
    default_backend pgsql_primary_backend

backend pgsql_primary_backend
    mode tcp
    balance first
    option tcp-check
    tcp-check connect
    tcp-check send-binary 00000027  # length
    tcp-check send-binary 00030000  # proto version
    tcp-check send-binary 7573657200  # user\0
    tcp-check send-binary 706f737467726573  # postgres
    tcp-check receive "N"
    server srv1-pg {{ server1_private_ip }}:{{ postgresql_port }} check inter 2s fall 3 rise 2
    server srv2-pg {{ server2_private_ip }}:{{ postgresql_port }} check inter 2s fall 3 rise 2 backup

# ── PostgreSQL replicas (read-only) ───────────────────────────────────────
frontend pgsql_replica
    bind *:5001
    mode tcp
    option tcplog
    default_backend pgsql_replica_backend

backend pgsql_replica_backend
    mode tcp
    balance leastconn
    server srv2-pg-ro {{ server2_private_ip }}:{{ postgresql_port }} check inter 2s
    server srv1-pg-ro {{ server1_private_ip }}:{{ postgresql_port }} check inter 2s backup
