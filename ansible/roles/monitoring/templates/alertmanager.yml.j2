global:
  resolve_timeout: 5m
  slack_api_url: {{ slack_webhook_url }}

route:
  group_by: [alertname, cluster, service]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: slack-notifications
  routes:
    - match:
        severity: critical
      receiver: critical-alerts
      continue: true
    - match:
        severity: warning
      receiver: slack-notifications

receivers:
  - name: slack-notifications
    slack_configs:
      - channel: "#nebula-alerts"
        username: AlertManager
        icon_emoji: ":warning:"
        title: "[{{ "{{" }} .Status | toUpper {{ "}}" }}] {{ "{{" }} .CommonLabels.alertname {{ "}}" }}"
        text: "{{ "{{" }} range .Alerts {{ "}}" }}{{ "{{" }} .Annotations.summary {{ "}}" }}\n{{ "{{" }} end {{ "}}" }}"
        send_resolved: true

  - name: critical-alerts
    slack_configs:
      - channel: "#nebula-critical"
        username: AlertManager
        icon_emoji: ":rotating_light:"
        title: ":rotating_light: CRITICAL: {{ "{{" }} .CommonLabels.alertname {{ "}}" }}"
        text: "{{ "{{" }} range .Alerts {{ "}}" }}{{ "{{" }} .Annotations.summary {{ "}}" }}\n{{ "{{" }} end {{ "}}" }}"
        send_resolved: true
    email_configs:
      - to: {{ alert_email }}
        send_resolved: true

inhibit_rules:
  - source_match:
      severity: critical
    target_match:
      severity: warning
    equal: [alertname, instance]
