PORT=3002

# JWT (must match game-server JWT_SECRET for cross-service token validation)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# PostgreSQL — connect via PgBouncer (port 6432)
DB_HOST=localhost
DB_PORT=6432
DB_USERNAME=nebula
DB_PASSWORD=change-me
DB_DATABASE=nebula_dominion
DB_SSL=false

# PgBouncer-aware pool settings
# Keep TypeORM pool small — PgBouncer does the real pooling
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=10000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000

# Security
BCRYPT_ROUNDS=12

# CORS (comma-separated origins or * for dev)
CORS_ORIGIN=*

# Environment
NODE_ENV=development
