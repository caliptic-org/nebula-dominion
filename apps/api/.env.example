# =============================================
# Nebula Dominion - API Service
# =============================================

# Application
NODE_ENV=development
PORT=3000

# PostgreSQL Database
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://nebula:nebula_password@localhost:5432/nebula_dominion

# Individual DB options (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nebula
DB_PASSWORD=nebula_password
DB_DATABASE=nebula_dominion
DB_SSL=false

# TypeORM
# Set to true in development to auto-create/update tables
DB_SYNCHRONIZE=false
# Set to true to log all SQL queries
DB_LOGGING=false

# Redis
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Password Hashing
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Cache (seconds)
CACHE_TTL=300

# Swagger Documentation
# Set to false in production if you want to disable docs
SWAGGER_ENABLED=true
