# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=nebula
DB_PASSWORD=strong_password_here
DB_NAME=nebula_dominion
DB_SSL=false

# App
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# JWT — both must be at least 32 characters (see configuration.ts)
JWT_SECRET=replace_me_with_a_random_string_of_32_or_more_chars
JWT_REFRESH_SECRET=replace_me_with_another_random_string_of_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# iyzico (Türkiye ödeme sistemi)
IYZICO_API_KEY=sandbox-...
IYZICO_SECRET_KEY=sandbox-...
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# KVKK/GDPR
CONSENT_VERSION=1.0
DATA_RETENTION_DAYS=1825

# Redis (önbellek)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
