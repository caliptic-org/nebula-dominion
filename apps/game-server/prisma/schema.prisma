generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BattleLog {
  id            String   @id @default(uuid())
  matchId       String
  roomId        String
  mode          String
  winnerId      String
  loserId       String
  winnerRace    String
  loserRace     String
  winnerEloGain Int
  loserEloLoss  Int
  totalTurns    Int
  durationMs    Int
  endReason     String
  rewards       Json
  createdAt     DateTime @default(now())

  @@index([winnerId])
  @@index([loserId])
  @@index([matchId])
  @@map("battle_logs")
}
