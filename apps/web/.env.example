# API & Game Server
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GAME_SERVER_URL=http://localhost:3001

# App
NEXT_PUBLIC_APP_URL=http://localhost:4000
NODE_ENV=development

# Guild backend gate (CAL-239 / CAL-241)
# When 'true', guildApi + guild-client (chat, donate, contribution) hit the
# real backend at NEXT_PUBLIC_API_URL (REST + socket.io /guild-chat namespace).
# Leave unset/false in local dev to keep working without auth.
# NEXT_PUBLIC_GUILD_BACKEND_READY=true
