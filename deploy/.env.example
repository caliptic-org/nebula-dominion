# ── Gitea ──────────────────────────────────────────────────────────────────────
GITEA_DOMAIN=gitea.local
GITEA_DB_PASSWORD=change-me-gitea-db

# ── Drone CI ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
DRONE_RPC_SECRET=change-me-drone-rpc-secret
DRONE_DOMAIN=drone.local
DRONE_DB_PASSWORD=change-me-drone-db

# Created in Gitea: Settings → Applications → OAuth2 Application
DRONE_GITEA_CLIENT_ID=
DRONE_GITEA_CLIENT_SECRET=

# ── Notifications ───────────────────────────────────────────────────────────────
SLACK_WEBHOOK=

# ── Drone secrets (set via drone CLI or UI) ─────────────────────────────────────
# drone secret add --repository org/nebula-dominion --name ssh_key       --data @~/.ssh/deploy_key
# drone secret add --repository org/nebula-dominion --name staging_host  --data "10.0.0.1"
# drone secret add --repository org/nebula-dominion --name prod_host     --data "10.0.0.2"
# drone secret add --repository org/nebula-dominion --name slack_webhook --data "<webhook-url>"
