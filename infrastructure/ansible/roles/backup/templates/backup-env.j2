# /etc/nebula/backup.env — sourced by all backup scripts
# Generated by Ansible — do not edit manually

SLACK_WEBHOOK_URL={{ slack_webhook_url | default('') }}
PROMETHEUS_PUSHGATEWAY={{ prometheus_pushgateway_url | default('') }}

# pgBackRest
PGBACKREST_STANZA=nebula
HETZNER_STORAGEBOX_HOST={{ hetzner_storagebox_host }}

# Redis
REDIS_HOST={{ redis_host | default('127.0.0.1') }}
REDIS_PORT={{ redis_port | default('6379') }}
REDIS_AUTH={{ redis_auth_password | default('') }}
REDIS_DATA_DIR={{ redis_data_dir | default('/var/lib/redis') }}
REDIS_BACKUP_DIR=/backup/redis
REDIS_BACKUP_RETENTION_DAYS=7

# Restic
RESTIC_REPOSITORY=sftp:nebula-backup@{{ hetzner_storagebox_host }}:/nebula-dominion/restic-config
RESTIC_PASSWORD={{ restic_password }}

# MinIO
MINIO_PRIMARY_ALIAS=minio-primary
MINIO_REPLICA_ALIAS=minio-replica
