[global]
log-level-console=info
log-level-file=detail
log-path=/var/log/pgbackrest
process-max=4
compress-type=lz4
compress-level=3
archive-async=y
archive-push-queue-max=1GiB

[global:repo1]
repo1-path=/backup/pgbackrest
repo1-retention-full=2
repo1-retention-diff=7
repo1-retention-archive=14
repo1-cipher-type=aes-256-cbc
repo1-cipher-pass={{ pgbackrest_repo1_cipher_pass }}

[global:repo2]
repo2-type=sftp
repo2-sftp-host={{ hetzner_storagebox_host }}
repo2-sftp-host-user=nebula-backup
repo2-sftp-host-key-hash-type=sha256
repo2-sftp-private-key-file=/etc/pgbackrest/ssh/id_ed25519
repo2-path=/nebula-dominion/pgbackrest
repo2-retention-full=4
repo2-retention-archive=30
repo2-cipher-type=aes-256-cbc
repo2-cipher-pass={{ pgbackrest_repo2_cipher_pass }}

[nebula]
pg1-path=/var/lib/postgresql/16/main
pg1-port=5432
pg1-socket-path=/var/run/postgresql
{% if pg_replica_host is defined %}
pg2-path=/var/lib/postgresql/16/main
pg2-port=5432
pg2-host={{ pg_replica_host }}
pg2-host-user=postgres
{% endif %}
