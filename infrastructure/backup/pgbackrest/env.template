# Copy to /etc/pgbackrest/pgbackrest.env and fill in values.
# Protect with: chmod 600 /etc/pgbackrest/pgbackrest.env

# Hetzner Storage Box connection
HETZNER_STORAGE_BOX_HOST=uXXXXXX.your-storagebox.de
HETZNER_STORAGE_BOX_USER=uXXXXXX

# Encryption passphrases — generate with: openssl rand -base64 32
PGBACKREST_REPO1_CIPHER_PASS=CHANGE_ME_REPO1_PASSPHRASE
PGBACKREST_REPO2_CIPHER_PASS=CHANGE_ME_REPO2_PASSPHRASE
