# Copy to /etc/restic/restic.env and fill in values.
# Protect with: chmod 600 /etc/restic/restic.env

# Hetzner Storage Box — SFTP backend
RESTIC_REPOSITORY=sftp:${HETZNER_STORAGE_BOX_USER}@${HETZNER_STORAGE_BOX_HOST}:/nebula-dominion/restic
HETZNER_STORAGE_BOX_HOST=uXXXXXX.your-storagebox.de
HETZNER_STORAGE_BOX_USER=uXXXXXX
RESTIC_PASSWORD=CHANGE_ME_RESTIC_PASSWORD   # openssl rand -base64 32

# MinIO connection (for MinIO export before backup)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_SECRET_KEY

# Slack webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Retention policy
RESTIC_KEEP_DAILY=30
RESTIC_KEEP_WEEKLY=12
RESTIC_KEEP_MONTHLY=12

# SSH key for Hetzner (same or separate from pgBackRest)
RESTIC_SSH_KEY=/root/.ssh/hetzner_backup_key
