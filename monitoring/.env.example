# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_strong_password
GRAFANA_ROOT_URL=https://grafana.nebula.internal

# ─── Alertmanager ────────────────────────────────────────────────────────────
ALERTMANAGER_URL=https://alertmanager.nebula.internal

# ─── Slack Integration ───────────────────────────────────────────────────────
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
# Get this from: Slack → Apps → Incoming Webhooks → Add New Webhook to Workspace
SLACK_API_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR_REAL_WEBHOOK

# ─── SMS Integration (webhook) ───────────────────────────────────────────────
# Webhook endpoint that accepts POST with JSON: {"text": "...", "to": ["..."] }
# Example providers: Twilio, Vonage, or custom SMS gateway
SMS_WEBHOOK_URL=https://your-sms-gateway/api/send
SMS_WEBHOOK_TOKEN=your_bearer_token_here

# ─── PostgreSQL Exporter ─────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname?sslmode=disable
POSTGRES_EXPORTER_DSN=postgresql://prometheus_exporter:exporter_password@postgres-primary:5432/nebula?sslmode=disable

# ─── Redis Exporter ──────────────────────────────────────────────────────────
REDIS_ADDR=redis://redis-master:6379
REDIS_PASSWORD=

# ─── GlitchTip ───────────────────────────────────────────────────────────────
GLITCHTIP_SECRET_KEY=changeme_very_long_random_secret_key_here_min_50_chars
GLITCHTIP_DB_PASSWORD=changeme_glitchtip_db_password
GLITCHTIP_DOMAIN=https://glitchtip.nebula.internal
GLITCHTIP_FROM_EMAIL=noreply@nebula.internal
# SMTP: smtp+tls://user:pass@host:port
GLITCHTIP_EMAIL_URL=consolemail://
