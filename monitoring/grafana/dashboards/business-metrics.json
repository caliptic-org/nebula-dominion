{
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Business Metrics: DAU, registration rate, session duration, retention, conversion",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Key Business Indicators",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "green", "value": 50 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "DAU (Daily Active Users)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "nebula_daily_active_users", "legendFormat": "DAU" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "MAU (Monthly Active Users)",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "nebula_monthly_active_users", "legendFormat": "MAU" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "New Registrations Today",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(nebula_user_registrations_total[24h])", "legendFormat": "registrations" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 600 },
            { "color": "green", "value": 1200 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Avg Session Duration",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "nebula_session_duration_seconds_avg", "legendFormat": "avg" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 25 },
            { "color": "green", "value": 35 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "D1 Retention",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "nebula_retention_d1_percent", "legendFormat": "D1 %" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 12 },
            { "color": "green", "value": 18 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "D7 Retention",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "nebula_retention_d7_percent", "legendFormat": "D7 %" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "User Growth & Engagement",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "DAU / MAU Trend",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "nebula_daily_active_users", "legendFormat": "DAU" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "nebula_monthly_active_users", "legendFormat": "MAU" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Registration Rate",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(nebula_user_registrations_total[1h]) * 3600", "legendFormat": "registrations/hour" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(nebula_user_logins_total[1h]) * 3600", "legendFormat": "logins/hour" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Conversion & Monetization",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "title": "Shop Visits vs Purchases",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(nebula_shop_visits_total[1h]) * 3600", "legendFormat": "shop visits/hour" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(nebula_purchases_total[1h]) * 3600", "legendFormat": "purchases/hour" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent", "min": 0, "max": 100 }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "title": "Funnel Conversion",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "nebula_tutorial_completion_percent", "legendFormat": "tutorial completion %" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "nebula_shop_conversion_percent", "legendFormat": "shop conversion %" }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["business", "retention", "dau"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Business Metrics",
  "uid": "business-metrics",
  "version": 1
}
