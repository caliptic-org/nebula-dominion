{
  "name": "nebula-dominion",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*"],
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm --filter @nebula-dominion/web build && pnpm --filter @nebula-dominion/game-server build",
    "build:web": "pnpm --filter @nebula-dominion/web build",
    "build:game-server": "pnpm --filter @nebula-dominion/game-server build",
    "dev:web": "pnpm --filter @nebula-dominion/web dev",
    "dev:game-server": "pnpm --filter @nebula-dominion/game-server start:dev",
    "start:game-server": "pnpm --filter @nebula-dominion/game-server start",
    "start:prod:game-server": "pnpm --filter @nebula-dominion/game-server start:prod",
    "test:game-server": "pnpm --filter @nebula-dominion/game-server test",
    "test:cov:game-server": "pnpm --filter @nebula-dominion/game-server test:cov"
  }
}
