{
  "name": "nebula-dominion",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "build": "pnpm -r run build",
    "build:game-server": "pnpm --filter @nebula-dominion/game-server run build",
    "build:api": "pnpm --filter @nebula-dominion/api run build",
    "start:game-server": "pnpm --filter @nebula-dominion/game-server run start",
    "start:api": "pnpm --filter @nebula-dominion/api run start",
    "start:dev:game-server": "pnpm --filter @nebula-dominion/game-server run start:dev",
    "start:dev:api": "pnpm --filter @nebula-dominion/api run start:dev",
    "test": "pnpm -r run test",
    "test:game-server": "pnpm --filter @nebula-dominion/game-server run test",
    "test:api": "pnpm --filter @nebula-dominion/api run test",
    "typecheck": "pnpm -r run typecheck"
  }
}
